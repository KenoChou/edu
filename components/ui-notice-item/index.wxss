.notice-item { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02); }
.item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15rpx; }
.title-row { display: flex; align-items: center; }
.dot { width: 12rpx; height: 12rpx; background: #ff4d4f; border-radius: 50%; margin-right: 12rpx; }
.item-title { font-size: 30rpx; font-weight: bold; color: #333; }
.item-time { font-size: 22rpx; color: #bbb; }
.item-content { font-size: 26rpx; color: #666; line-height: 1.5; margin-bottom: 20rpx; }
.item-footer { border-top: 1rpx solid #f5f5f5; padding-top: 20rpx; display: flex; justify-content: space-between; align-items: center; }
.type-tag { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.course { background: #e6f7ff; color: #1890ff; }
.income { background: #e8f5ed; color: #2d7d52; }
.system { background: #f5f5f5; color: #999; }
.detail-link { font-size: 22rpx; color: #6b5af0; }
