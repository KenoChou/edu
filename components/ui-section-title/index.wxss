.section-title-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-main {
  display: flex;
  align-items: center;
}

.section-line {
  width: 6rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: #3b82f6;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-extra {
  font-size: 24rpx;
  color: #64748b;
}
