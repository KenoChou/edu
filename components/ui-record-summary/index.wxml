<view class="summary-card">
  <view class="main-balance">
    <text class="num">{{remaining}}</text>
    <text class="unit">剩余总课时</text>
  </view>
  <view class="sub-info">
    <view class="info-item">
      <text class="v">{{totalLessons}}</text>
      <text class="l">总课时</text>
    </view>
    <view class="divider"></view>
    <view class="info-item">
      <text class="v">{{usedLessons}}</text>
      <text class="l">已上课</text>
    </view>
  </view>
</view>
