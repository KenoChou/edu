page { background: #F8FAFC; }

.nav-fixed { position: fixed; top: 0; left: 0; width: 100%; background: #fff; z-index: 100; border-bottom: 1rpx solid #F1F5F9; }
.nav-inner { display: flex; align-items: center; padding: 0 32rpx; height: 100%; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 600; padding-right: 80rpx; }
.back-btn { font-size: 48rpx; color: #0F172A; width: 60rpx; }

.main-content { width: 100vw; box-sizing: border-box; padding: 20rpx 0 28rpx; }

/* 标签页 */
.tab-bar {
  display: flex;
  gap: 12rpx;
  /* fixed 时使用 inline top/left/right 控制位置 */
  padding: 12rpx 24rpx;
  background: #F8FAFC;
  box-shadow: 0 8rpx 24rpx rgba(2,6,23,0.06);
  z-index: 110;
  border-radius: 24rpx;
}
.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 14rpx;
  position: relative;
  color: #64748B;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 16rpx;
  transition: all 0.18s ease;
}
.tab-item.active {
  color: #FFFFFF;
  background: #3B82F6;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.2);
}
.tab-item.active::after {
  display: none;
}
.badge {
  background: #EF4444;
  color: #fff;
  border-radius: 12rpx;
  padding: 0rpx 8rpx;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
}

/* swiper容器 */
.swiper-container {
  height: calc(100vh - 320rpx);
  border-radius: 16rpx;
}
.swiper-item {
  height: 100%;
  overflow-y: auto;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  min-height: 400rpx;
  gap: 24rpx;
  color: #94A3B8;
}
.empty-icon {
  font-size: 100rpx;
  color: #CBD5E1;
  line-height: 1;
}
.empty-text {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 列表 */
.cert-list { padding: 28rpx 12rpx; }
.cert-item {
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}
.cert-item:active {
  opacity: 0.9;
}
.cert-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(148, 163, 184, 0.08);
  border: 1rpx solid #E2E8F0;
  margin: 0 12rpx;
}
.cert-header {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  gap: 22rpx;
  position: relative;
}
.cert-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #F1F5F9;
  flex-shrink: 0;
}
.cert-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.cert-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  line-height: 1.3;
}
.cert-teacher {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}
.cert-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.cert-date {
  font-size: 22rpx;
  color: #94A3B8;
}
.cert-footer {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 40rpx;
  background: #F8FAFC;
  border-top: 1rpx solid #E2E8F0;
}
.cert-detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.detail-label {
  font-size: 20rpx;
  color: #94A3B8;
}
.detail-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #3B82F6;
}
.status-badge {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  min-width: 100rpx;
  text-align: center;
}
.status-badge.pending {
  background: #FEF3C7;
  color: #D97706;
}
.status-badge.approved {
  background: #DCFCE7;
  color: #16A34A;
}
.status-badge.rejected {
  background: #FEE2E2;
  color: #DC2626;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: slideIn 0.3s ease-out;
}
@keyframes slideIn {
  from {
    background: rgba(0, 0, 0, 0);
  }
  to {
    background: rgba(0, 0, 0, 0.5);
  }
}
.detail-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: 60rpx;
  max-height: 90vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease-out;
}
@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx 24rpx;
  margin-bottom: 0;
  border-bottom: none;
}
.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0F172A;
}
.close-btn {
  font-size: 48rpx;
  color: #64748B;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-body {
  padding: 0;
}
.teacher-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #EFF6FF 0%, #F8FAFC 100%);
  border-bottom: 1rpx solid #E2E8F0;
}
.teacher-avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  background: #F1F5F9;
  flex-shrink: 0;
}
.teacher-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.teacher-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}
.teacher-cert {
  font-size: 26rpx;
  color: #3B82F6;
  font-weight: 600;
}
.teacher-meta {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 信息卡片 */
.info-card {
  padding: 40rpx 32rpx;
}
.info-header {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #E2E8F0;
}
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
}
.info-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
  background: #F8FAFC;
  border-radius: 20rpx;
  border: 1rpx solid #E2E8F0;
}
.info-label {
  font-size: 22rpx;
  color: #64748B;
  font-weight: 500;
}
.info-content {
  font-size: 24rpx;
  color: #0F172A;
  font-weight: 600;
}

/* 证书图片部分 */
.cert-image-section {
  padding: 40rpx 32rpx 60rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 20rpx;
}
.detail-cert-image {
  width: 100%;
  height: 420rpx;
  border-radius: 20rpx;
  background: #F1F5F9;
  border: 1rpx solid #E2E8F0;
}

/* 操作按钮 */
.detail-footer {
  padding: 40rpx 32rpx;
  border-top: 1rpx solid #E2E8F0;
  margin-top: 0;
  background: #FFFFFF;
  position: sticky;
  bottom: 0;
}
.btn-group {
  display: flex;
  gap: 16rpx;
}
.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}
.btn-approve {
  background: #10B981;
  color: #fff;
}
.btn-approve:active {
  background: #059669;
}
.btn-reject {
  background: #FFFFFF;
  color: #EF4444;
  border: 2rpx solid #FEE2E2;
}
.btn-reject:active {
  background: #FEF2F2;
}
