/* 彻底清除小程序默认的页面边距 */
page { 
  background: #FFFFFF; 
  width: 100%;
  margin: 0;
  padding: 0;
}

.screen-container { width: 100%; overflow-x: hidden; }

/* 导航栏 */
.nav-fixed { position: fixed; top: 0; left: 0; width: 100%; background: #fff; z-index: 100; border-bottom: 1rpx solid #F2F2F2; }
.nav-inner { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative; }
.back-btn { position: absolute; left: 40rpx; color: #3B82F6; font-size: 38rpx; }
.nav-title { font-size: 30rpx; font-weight: 700; letter-spacing: 2rpx; }

/* 1. 顶部蓝色条：彻底撞边 */
.hero-banner {
  width: 100vw; /* 强制占据屏幕全宽 */
  background: #3B82F6;
  padding: 60rpx 0;
  display: flex;
  align-items: center;
}
.hero-item { flex: 1; text-align: center; }
.hero-item .v { display: block; font-size: 50rpx; font-weight: 800; color: #fff; }
.hero-item .l { font-size: 18rpx; color: rgba(255,255,255,0.6); letter-spacing: 4rpx; margin-top: 10rpx; }
.hero-sep { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.2); }

/* 2. 列表：每一行都吃满宽度 */
.edge-to-edge-list { width: 100vw; }

.stu-row {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 45rpx 40rpx; /* 内部文字缩进，保持美感，但背景/线是撞边的 */
  box-sizing: border-box;
  border-bottom: 1rpx solid #F7F9FB;
}

/* 点击整行时的淡蓝色全屏反馈 */
.stu-row:active { background: #F4F9FF; }

.row-left { display: flex; align-items: center; }
.avatar-tag {
  width: 54rpx; height: 54rpx; background: #EBF4FF; color: #3B82F6;
  font-size: 24rpx; font-weight: bold; border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center; margin-right: 24rpx;
}
.name-box { display: flex; flex-direction: column; }
.n { font-size: 36rpx; font-weight: 800; color: #1A1A1A; }
.c { font-size: 22rpx; color: #94A3B8; margin-top: 6rpx; }

.row-right { text-align: right; }
/* 将数字做成精致的小圆圈或药丸包围，填充横向空间 */
.hrs-circle {
  display: inline-flex; align-items: baseline;
  padding: 8rpx 24rpx; background: #F0F7FF; border-radius: 100rpx;
  margin-bottom: 10rpx;
}
.hrs-circle .val { font-size: 34rpx; font-weight: 800; color: #3B82F6; }
.hrs-circle .unit { font-size: 16rpx; color: #3B82F6; margin-left: 6rpx; font-weight: bold; }
.date { display: block; font-size: 18rpx; color: #CBD5E1; letter-spacing: 2rpx; }

.database-footer { 
  text-align: center; font-size: 18rpx; color: #E2E8F0; 
  padding: 100rpx 0; letter-spacing: 12rpx; font-weight: bold;
}