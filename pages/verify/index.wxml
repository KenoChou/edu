<view class="page-container">
  <view class="nav-fixed" style="padding-top: {{navTop}}px;">
    <view class="nav-content" style="height: {{navHeight}}px;">
      <view class="back-btn" bindtap="goBack">〈</view>
      <text class="title">实名认证</text>
    </view>
  </view>

  <view class="main-content" style="margin-top: {{navTop + navHeight + 20}}px;">
    <view class="verify-header">
      <view class="shield-icon">🛡️</view>
      <view class="header-txt">
        <text class="h-main">信息安全保障中</text>
        <text class="h-sub">认证信息仅用于身份核验，我们将严格保密</text>
      </view>
    </view>

    <view class="form-card">
      <view class="form-item">
        <text class="label">真实姓名</text>
        <input class="input" placeholder="请输入姓名" placeholder-class="p-class" bindinput="onInputName" />
      </view>
      <view class="form-item">
        <text class="label">身份证号</text>
        <input class="input" type="idcard" placeholder="请输入18位身份证号" placeholder-class="p-class" bindinput="onInputId" />
      </view>
    </view>

    <view class="protocol-row" bindtap="onCheckAgree">
      <view class="checkbox {{isAgreed ? 'checked' : ''}}">
        <text wx:if="{{isAgreed}}">✓</text>
      </view>
      <text class="p-text">我已阅读并同意 <text class="link">《用户实名认证服务协议》</text></text>
    </view>

    <button class="submit-btn {{isAgreed && name && idCard ? 'active' : ''}}" bindtap="submitVerify">提交认证</button>

    <view class="verify-footer">
      <text>如有疑问，请联系课程顾问</text>
    </view>
  </view>
</view>