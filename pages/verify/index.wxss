page { background-color: #F8FAFC; }

/* 导航样式同上... (建议封装成组件或复用) */
.nav-fixed { position: fixed; top: 0; left: 0; width: 100%; background: #F8FAFC; z-index: 100; }
.nav-content { display: flex; align-items: center; padding: 0 32rpx; }
.back-btn { font-size: 40rpx; color: #1E293B; font-weight: bold; width: 60rpx; }
.title { font-size: 34rpx; font-weight: 600; color: #0F172A; }

.main-content { padding: 40rpx; }

/* 头部安全样式 */
.verify-header {
  display: flex; align-items: center; background: #E8F0FF;
  padding: 30rpx; border-radius: 20rpx; margin-bottom: 40rpx;
}
.shield-icon { font-size: 60rpx; margin-right: 24rpx; }
.h-main { display: block; font-size: 30rpx; font-weight: 600; color: #3B82F6; }
.h-sub { font-size: 22rpx; color: #60A5FA; }

/* 表单卡片 */
.form-card { background: #fff; border-radius: 32rpx; padding: 0 32rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02); }
.form-item {
  display: flex; align-items: center; padding: 40rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}
.form-item:last-child { border-bottom: none; }
.label { width: 160rpx; font-size: 28rpx; color: #64748B; font-weight: 500; }
.input { flex: 1; font-size: 30rpx; color: #1E293B; }
.p-class { color: #CBD5E1; }

/* 协议勾选 */
.protocol-row { display: flex; align-items: center; margin-top: 40rpx; padding: 0 10rpx; }
.checkbox {
  width: 32rpx; height: 32rpx; border: 2rpx solid #CBD5E1; border-radius: 8rpx;
  margin-right: 16rpx; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.checkbox.checked { background: #3B82F6; border-color: #3B82F6; color: #fff; font-size: 22rpx; }
.p-text { font-size: 24rpx; color: #94A3B8; }
.link { color: #3B82F6; }

/* 提交按钮 */
.submit-btn {
  margin-top: 80rpx; height: 100rpx; line-height: 100rpx;
  background: #DBEAFE; color: #fff; border-radius: 50rpx;
  font-size: 32rpx; font-weight: 600; border: none;
}
.submit-btn.active { background: #3B82F6; box-shadow: 0 12rpx 24rpx rgba(59, 130, 246, 0.3); }

.verify-footer { text-align: center; margin-top: 40rpx; font-size: 24rpx; color: #CBD5E1; }