<view class="page-container">
  <view class="nav-overlay" style="top: {{statusBarHeight}}px; height: {{navHeight}}px">
    <view class="glass-back" bindtap="goBack">
      <view class="arrow-white"></view>
    </view>
  </view>

  <view class="hero-section">
    <image class="hero-image" src="https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=800" mode="aspectFill"></image>
    <view class="hero-gradient-top"></view>
    <view class="hero-gradient-bottom"></view>
  </view>

  <view class="main-body">
    <view class="card price-card">
      <view class="card-title-row">
        <text class="course-name">{{courseName}}</text>
        <view class="price-info">
          <text class="yen">¥</text>
          <text class="num">{{coursePrice}}</text>
          <text class="unit">/课时</text>
        </view>
      </view>
      <view class="tag-row">
        <text class="tag-purple" wx:for="{{courseTags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="card">
      <view class="sec-header">
        <view class="indicator"></view>
        <text>课程介绍</text>
      </view>
      <view class="sec-content">{{courseDesc}}</view>
    </view>

    <view class="card teacher-card">
      <view class="sec-header">
        <view class="indicator"></view>
        <text>授课老师</text>
        <view class="change-btn" bindtap="onChangeTeacher">查看/更换 ></view>
      </view>
      <view class="ai-box" bindtap="onChangeTeacher">
        <view class="ai-avatar">🤖</view>
        <view class="ai-info">
          <view class="ai-name">{{selectedTeacherName}}</view>
          <view class="ai-tips">{{selectedTeacherTips}}</view>
        </view>
        <view class="ai-arrow"></view>
      </view>
    </view>

    <view class="card">
      <view class="sec-header">
        <view class="indicator"></view>
        <text>订课套餐</text>
      </view>
      <view class="package-list">
        <view
          class="package-item {{item.active ? 'active' : ''}}"
          wx:for="{{packageList}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onSelectPackage"
        >
          <view>
            <view class="package-title">{{item.title}}</view>
            <view class="package-lessons">{{item.lessons}} 课时</view>
          </view>
          <view class="package-price">¥{{item.totalPrice}}</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="sec-header">
        <view class="indicator"></view>
        <text>备注信息</text>
      </view>
      <textarea
        class="remark-input"
        placeholder="请输入上课偏好、时间需求等（选填）"
        maxlength="120"
        value="{{remark}}"
        bindinput="onRemarkInput"
      ></textarea>
    </view>

    <view class="agree-row" bindtap="toggleAgree">
      <view class="agree-check {{agreed ? 'active' : ''}}"></view>
      <text>我已阅读并同意《课程服务协议》</text>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="action-icons">
      <view class="icon-unit">
        <view class="icon-img">💬</view>
        <text>咨询</text>
      </view>
      <view class="icon-unit {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
        <view class="icon-img">{{isFavorite ? '⭐' : '☆'}}</view>
        <text>{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
    </view>
    <button class="order-submit-btn" loading="{{submitting}}" bindtap="handleSubmitOrder">立即预订</button>
  </view>
</view>
