<view class="page">
  <view class="fixed-top" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-bar" style="height: {{navHeight}}px">
      <view class="back-area" bindtap="goBack" >
        <view class="custom-back-icon"></view>
      </view>
      <view class="search-outer" style="width: {{searchWidth}}px">
        <view class="search-inner">
          <icon type="search" size="14" color="#999"></icon>
          <input placeholder="搜索课程" placeholder-style="color:#B0B0B0" />
        </view>
      </view>
    </view>

    <scroll-view scroll-x enable-flex class="tab-strip">
      <view
        class="tab-btn {{currentTab == index ? 'active' : ''}}"
        wx:for="{{tabs}}" wx:key="index"
        bindtap="switchTab" data-index="{{index}}"
      >
        {{item}}
      </view>
    </scroll-view>
  </view>

  <view class="main-content" style="padding-top: {{statusBarHeight + navHeight + 60}}px">
    <view wx:if="{{displayedCourses.length === 0}}" class="empty-state">
      <view class="sad-face">☹</view>
      <text>暂无相关课程</text>
    </view>

    <view wx:else class="course-list">
      <view class="course-card" wx:for="{{displayedCourses}}" wx:key="id" data-id="{{item.id}}" bindtap="goToDetail">
        <image class="cover" src="{{item.cover}}" mode="aspectFill"></image>
        <view class="right">
          <view class="title">{{item.name}}</view>
          <view class="desc">{{item.desc}}</view>
          <view class="bottom">
            <text class="tag">{{item.category}}</text>
            <text class="price">¥{{item.price}}/课时</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
