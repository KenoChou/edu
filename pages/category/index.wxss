page { background: #f8f9fb; }
.fixed-top { position: fixed; top: 0; left: 0; right: 0; background: #fff; z-index: 1000; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02); }
.nav-bar { display: flex; align-items: center; padding: 0 20rpx; }
.back-area { width: 70rpx; height: 100%; display: flex; align-items: center; justify-content: center; }
.custom-back-icon { width: 20rpx; height: 20rpx; border-left: 4rpx solid #333; border-bottom: 4rpx solid #333; transform: rotate(45deg); }
.search-outer { height: 72rpx; }
.search-inner { background: #f4f5f7; height: 100%; border-radius: 36rpx; display: flex; align-items: center; padding: 0 30rpx; }
.search-inner input { flex: 1; font-size: 28rpx; margin-left: 12rpx; }
.tab-strip { white-space: nowrap; height: 100rpx; display: flex; align-items: center; padding: 0 10rpx; }
.tab-btn { display: inline-block; padding: 12rpx 32rpx; margin: 0 12rpx; background: #f5f6f8; border-radius: 32rpx; font-size: 26rpx; color: #666; border: 1rpx solid transparent; }
.tab-btn.active { background: #fff; color: #3a86ff; border: 2rpx solid #3a86ff; font-weight: 500; }
.main-content { padding-left: 24rpx; padding-right: 24rpx; box-sizing: border-box; }
.course-card { background: #fff; border-radius: 20rpx; padding: 20rpx; display: flex; margin-bottom: 20rpx; }
.cover { width: 180rpx; height: 140rpx; border-radius: 14rpx; margin-right: 20rpx; }
.right { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.title { font-size: 30rpx; color: #1f2937; font-weight: 600; }
.desc { font-size: 24rpx; color: #6b7280; line-height: 1.4; }
.bottom { display: flex; justify-content: space-between; align-items: center; }
.tag { font-size: 22rpx; color: #3a86ff; background: #ecf4ff; padding: 4rpx 12rpx; border-radius: 12rpx; }
.price { font-size: 24rpx; color: #ef4444; font-weight: 600; }
.empty-state { display: flex; flex-direction: column; align-items: center; color: #c0c4cc; padding-top: 300rpx; }
.sad-face { font-size: 120rpx; margin-bottom: 20rpx; opacity: 0.5; }
