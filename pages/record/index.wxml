<view class="page-container">
  <ui-page-nav
    top="{{navTop}}"
    height="{{navHeight}}"
    title="课时记录"
    background="#f7f8fa"
    bind:back="goBack"
  />

  <view class="content-body">
    <ui-record-summary
      remaining="{{remaining}}"
      totalLessons="{{totalLessons}}"
      usedLessons="{{usedLessons}}"
    />

    <ui-section-title title="记录明细" />
    <view class="record-list">
      <ui-record-item wx:for="{{records}}" wx:key="id" record="{{item}}" />
    </view>
  </view>
</view>
