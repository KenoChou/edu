page { background-color: #f7f8fa; width: 100%; }
.page-container { width: 100%; display: flex; flex-direction: column; }

.content-body { padding: 32rpx; width: 100%; box-sizing: border-box; }

.summary-card {
  background: linear-gradient(135deg, #2d7d52, #4fac7d);
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(45, 125, 82, 0.2);
  margin-bottom: 50rpx;
}
.main-balance { text-align: center; margin-bottom: 40rpx; }
.main-balance .num { font-size: 88rpx; font-weight: bold; display: block; }
.main-balance .unit { font-size: 26rpx; opacity: 0.8; }

.sub-info { display: flex; justify-content: space-around; align-items: center; border-top: 1rpx solid rgba(255,255,255,0.2); padding-top: 30rpx; }
.info-item { text-align: center; }
.info-item .v { display: block; font-size: 36rpx; font-weight: bold; }
.info-item .l { font-size: 22rpx; opacity: 0.7; }
.divider { width: 1rpx; height: 40rpx; background: rgba(255,255,255,0.3); }

.record-item {
  background: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.item-left { display: flex; flex-direction: column; }
.item-name { font-size: 28rpx; font-weight: 500; color: #333; margin-bottom: 8rpx; }
.item-time { font-size: 22rpx; color: #999; }

.item-right { text-align: right; }
.amount { font-size: 32rpx; font-weight: bold; display: block; }
.plus { color: #2d7d52; }
.minus { color: #ff4d4f; }
.status { font-size: 20rpx; color: #bbb; }
