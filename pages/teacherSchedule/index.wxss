page { background: #F8FAFC; }

.nav-fixed { position: fixed; top: 0; left: 0; width: 100%; background: #fff; z-index: 100; border-bottom: 1rpx solid #F1F5F9; }
.nav-inner { display: flex; align-items: center; padding: 0 32rpx; height: 100%; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 600; padding-right: 80rpx; }

.main-content { padding: 30rpx 40rpx; }
.month-label { font-size: 38rpx; font-weight: 800; color: #1e293b; margin-bottom: 40rpx; }

/* 时间轴 */
.axis-left { width: 40rpx; display: flex; flex-direction: column; align-items: center; }
.dot { width: 14rpx; height: 14rpx; background: #CBD5E1; border-radius: 50%; margin-top: 10rpx; }
.dot.active { background: #3B82F6; box-shadow: 0 0 0 6rpx rgba(59, 130, 246, 0.15); }
.line { flex: 1; width: 2rpx; background: #E2E8F0; margin: 10rpx 0; }

.axis-right { flex: 1; margin-left: 24rpx; padding-bottom: 60rpx; }
.card-header-info { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.date-txt { font-size: 26rpx; font-weight: 700; color: #334155; }
.time-txt { font-size: 24rpx; color: #94A3B8; }

/* 充实的卡片设计 */
.expanded-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(148, 163, 184, 0.1);
  border: 1rpx solid rgba(226, 232, 240, 0.5);
  width: 580rpx;
  box-sizing: border-box;
}

.main-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0; }
.c-title { font-size: 32rpx; font-weight: 700; color: #0F172A; flex: 1; }
.stu-tag { font-size: 22rpx; color: #fff; background: #3B82F6; padding: 8rpx 16rpx; border-radius: 16rpx; display: inline-block; flex-shrink: 0; }

/* 数据详情区 (解决空旷感的关键) */
.data-preview {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.preview-row { display: flex; margin-bottom: 12rpx; }
.preview-row:last-child { margin-bottom: 0; }
.preview-row .label { font-size: 22rpx; color: #94A3B8; width: 110rpx; flex-shrink: 0; }
.preview-row .val { font-size: 24rpx; color: #475569; line-height: 1.5; }

/* 卡片底栏 */
.card-footer {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 20rpx; border-top: 1rpx solid #F1F5F9;
}
.rating-stars { font-size: 22rpx; color: #64748B; }
.star { color: #FBBF24; margin-left: 4rpx; }
.more-link { font-size: 24rpx; color: #3B82F6; font-weight: 600; }