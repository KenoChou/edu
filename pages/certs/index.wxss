page { background-color: #f7f8fa; width: 100%; }
.page-root { width: 100%; }

.header { background-color: #f7f8fa; width: 100%; position: sticky; top: 0; z-index: 100; }
.nav-bar { display: flex; align-items: center; padding: 0 32rpx; }
.back-btn { font-size: 44rpx; width: 60rpx; }
.nav-title { font-size: 34rpx; font-weight: bold; }

.main-body { padding: 30rpx 32rpx; box-sizing: border-box; }

.tips { font-size: 24rpx; color: #999; margin-bottom: 30rpx; }

/* 证书卡片 */
.cert-card {
  background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}
.cert-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15rpx; }
.cert-name { font-size: 30rpx; font-weight: bold; color: #333; }

.cert-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.success { background: #e8f5ed; color: #2d7d52; }
.pending { background: #fff7e6; color: #faad14; }

.cert-date { font-size: 24rpx; color: #999; margin-bottom: 20rpx; }
.cert-img { width: 100%; height: 240rpx; border-radius: 12rpx; background: #f5f5f5; }
.cert-placeholder { 
  width: 100%; height: 240rpx; border-radius: 12rpx; background: #f9f9f9;
  display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #ccc;
}

/* 上传框 */
.upload-box {
  width: 100%; height: 200rpx; border: 2rpx dashed #ccc; border-radius: 20rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.5);
}
.plus { font-size: 60rpx; color: #999; line-height: 1; margin-bottom: 10rpx; }
.upload-text { font-size: 26rpx; color: #666; }

.mock-banner { background: #fff7e6; color: #ad6800; border-radius: 14rpx; padding: 20rpx; font-size: 24rpx; margin-bottom: 20rpx; }
.mock-banner.ok { background: #f6ffed; color: #2d7d52; }
.mock-btn { margin-bottom: 24rpx; background: #3a86ff; color: #fff; border-radius: 12rpx; font-size: 26rpx; }
