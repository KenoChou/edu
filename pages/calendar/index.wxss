.page { background: #fff; min-height: 100vh; }

/* 导航对齐 */
.nav-fixed { position: sticky; top: 0; background: #fff; z-index: 99; padding-bottom: 20rpx; }
.nav-content { display: flex; align-items: center; padding: 0 30rpx; gap: 20rpx; }
.nav-title { font-size: 36rpx; font-weight: bold; }
.nav-tabs { display: flex; background: #f0f2f5; border-radius: 40rpx; padding: 4rpx; }
.tab { padding: 8rpx 24rpx; font-size: 24rpx; border-radius: 30rpx; color: #666; }
.tab.active { background: #fff; color: #3a86ff; font-weight: bold; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.nav-tag { background: #eef6ff; color: #3a86ff; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; margin-left: auto; margin-right: 200rpx; }

/* 日期条 */
.date-bar { display: flex; padding: 20rpx 30rpx; white-space: nowrap; height: 140rpx; }
.date-item { min-width: 90rpx; height: 110rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; border: 1rpx solid #f0f0f0; border-radius: 16rpx; margin-right: 20rpx; }
.date-item.active { background: #3a86ff; color: #fff; border-color: #3a86ff; box-shadow: 0 8rpx 16rpx rgba(58,134,255,0.2); }
.w { font-size: 20rpx; opacity: 0.8; margin-bottom: 6rpx; }
.d { font-size: 32rpx; font-weight: bold; }

/* 核心：时间轴列表 */
.list { padding: 30rpx; }
.item { display: flex; min-height: 180rpx; margin-bottom: 10rpx; }

/* 轴线实现 */
.left { width: 140rpx; padding-left: 20rpx; border-left: 6rpx solid #eee; display: flex; flex-direction: column; }
.border-blue { border-left-color: #3a86ff; }
.border-orange { border-left-color: #ff9f43; }
.border-gray { border-left-color: #c4c7ce; }

.t { font-size: 36rpx; font-weight: bold; color: #333; margin-top: -6rpx; }
.s { font-size: 22rpx; color: #999; margin-top: 6rpx; }

/* 卡片 */
.right { flex: 1; padding-left: 30rpx; }
.card-h { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.ct { font-size: 32rpx; font-weight: bold; }
.bt { font-size: 22rpx; color: #999; background: #f5f5f5; padding: 4rpx 12rpx; border-radius: 6rpx; }

.card-b { display: flex; justify-content: space-between; align-items: center; font-size: 26rpx; color: #666; }
.user { display: flex; align-items: center; }
.av { width: 44rpx; height: 44rpx; border-radius: 50%; color: #fff; font-size: 22rpx; display: flex; align-items: center; justify-content: center; margin-right: 12rpx; }
.loc { color: #999; }

.bg-blue { background: #3a86ff; }
.bg-orange { background: #ff9f43; }
.bg-gray { background: #c4c7ce; }

.loading { font-size: 24rpx; color: #999; text-align: center; padding: 40rpx 0; }
.empty { font-size: 24rpx; color: #bbb; text-align: center; padding: 40rpx 0; }
/* ============================= */
/* 按人员模式 */
/* ============================= */

.person-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
}

/* 人员头部 */
.person-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.person-header .av {
  width: 56rpx;
  height: 56rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.pn {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.count {
  font-size: 22rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 人员课程列表 */
.person-course {
  display: flex;
  padding: 20rpx 0;
  border-top: 1rpx solid #f5f5f5;
}

.person-course:first-of-type {
  border-top: none;
}

/* 左侧时间 */
.pc-left {
  width: 140rpx;
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* 右侧内容 */
.pc-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.pc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.pc-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.room {
  color: #999;
}

.status {
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #666;
}
.person-header {
  position: sticky;
  top: 0;
  background: #fff;
  z-index: 2;
  padding-bottom: 10rpx;
}