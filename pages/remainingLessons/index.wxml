<view class="page-wrap">
  <view class="immersion-header" style="padding-top: {{navTop}}px;">
    
    <view class="custom-nav" style="height: {{navHeight}}px;">
      <view class="back-area" bindtap="goBack">
        <text class="back-icon">〈</text>
      </view>
      <text class="nav-title">课时详情</text>
    </view>

    <view class="balance-main">
      <text class="label">剩余课时总计</text>
      <view class="num-box">
        <text class="big-num">12</text>
        <text class="unit">节</text>
      </view>
      <text class="date-tag">有效期至：2026.12.31</text>
    </view>
  </view>

  <view class="log-container">
    <view class="list-head">USAGE LOG / 消耗记录</view>
    <view class="log-item" wx:for="{{history}}" wx:key="index">
      <view class="info">
        <text class="name">{{item.className}}</text>
        <text class="time">{{item.date}} {{item.time}}</text>
      </view>
      <view class="side">
        <text class="minus">-1</text>
        <text class="status">已扣除</text>
      </view>
    </view>
  </view>
</view>