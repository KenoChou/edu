<view class="register-container">
  <view class="nav-bar" style="padding-top: {{navTop}}px; height: {{navHeight}}px;">
    <view class="back-icon" bindtap="goBack">〈</view>
  </view>

  <view class="register-content">
    <view class="welcome-section">
      <text class="main-title">创建账号</text>
      <text class="sub-title">注册后即可开始选课与学习</text>
    </view>

    <view class="register-form">
      <view class="input-group">
        <text class="prefix">+86</text>
        <input class="f-input" type="number" maxlength="11" placeholder="请输入手机号"
          placeholder-class="p-style" value="{{phone}}" bindinput="onPhoneInput" />
      </view>

      <view class="input-group">
        <input class="f-input" maxlength="20" placeholder="请输入昵称"
          placeholder-class="p-style" value="{{nickname}}" bindinput="onNicknameInput" />
      </view>

      <view class="input-group">
        <input class="f-input" password maxlength="20" placeholder="请设置密码（至少6位）"
          placeholder-class="p-style" value="{{password}}" bindinput="onPasswordInput" />
      </view>

      <view class="input-group">
        <input class="f-input" password maxlength="20" placeholder="请确认密码"
          placeholder-class="p-style" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>

      <view class="input-group">
        <input class="f-input" type="number" maxlength="6" placeholder="请输入验证码"
          placeholder-class="p-style" value="{{code}}" bindinput="onCodeInput" />
        <text class="get-code {{isCounting ? 'disabled' : ''}}" bindtap="getCode">{{codeText}}</text>
      </view>
    </view>

    <button class="register-btn {{canSubmit ? 'active' : ''}}" bindtap="handleRegister">完成注册</button>

    <view class="login-entry">
      <text class="login-tip">已有账号？</text>
      <text class="login-link" bindtap="goLogin">去登录</text>
    </view>
  </view>
</view>
