/* 彻底解决状态栏和宽度问题 */
page {
  background-color: #f7f8fa;
  width: 100%;
  height: 100%;
}

.page-root {
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* 导航头修复：背景色撑满最顶端 */
.header-box {
  background-color: #f7f8fa; /* 与页面背景一致，消除白条 */
  width: 100%;
  position: sticky;
  top: 0;
  z-index: 999;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.back-area {
  width: 60rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.back-arrow { font-size: 44rpx; font-weight: bold; color: #333; }
.nav-title { font-size: 34rpx; font-weight: bold; margin-left: 10rpx; }

/* 内容区修复：撑满宽度 */
.main-content {
  width: 100%;
  padding: 30rpx 32rpx;
  box-sizing: border-box; /* 必须加，防止padding撑破宽度 */
}

/* 账户卡片还原图15 */
.account-card {
  background: #1c222d;
  width: 100%;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 30rpx rgba(0,0,0,0.15);
}

.card-inner {
  padding: 50rpx 40rpx;
  position: relative;
  z-index: 2;
}

.card-label { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.balance-text { 
  display: block;
  font-size: 80rpx; 
  font-weight: bold; 
  color: #fff; 
  margin: 20rpx 0 40rpx;
}

.recharge-btn {
  display: inline-block;
  background: #fff;
  color: #1c222d;
  padding: 16rpx 44rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 交易记录列表 */
.record-section { margin-top: 50rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 24rpx; }

.record-item {
  background: #fff;
  width: 100%;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.type { display: block; font-size: 30rpx; font-weight: 500; color: #333; }
.date { font-size: 24rpx; color: #999; margin-top: 10rpx; }
.item-right { font-size: 32rpx; font-weight: bold; color: #2d7d52; }