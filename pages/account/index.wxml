<view class="page-root">
  <view class="header-box" style="padding-top: {{menuTop}}px;">
    <view class="nav-bar" style="height: {{menuHeight}}px;">
      <view class="back-area" bindtap="goBack">
        <text class="back-arrow">←</text>
      </view>
      <text class="nav-title">我的账户</text>
    </view>
  </view>

  <view class="main-content">
    <view class="account-card">
      <view class="card-inner">
        <text class="card-label">账户余额 (元)</text>
        <text class="balance-text">0.00</text>
        <view class="recharge-btn">立即充值</view>
      </view>
      <view class="card-pattern"></view>
    </view>

    <view class="record-section">
      <view class="section-title">交易记录</view>
      <view class="record-item">
        <view class="item-left">
          <text class="type">充值</text>
          <text class="date">2023-10-15</text>
        </view>
        <view class="item-right">+500.00</view>
      </view>
    </view>
  </view>
</view>