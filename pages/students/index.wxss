page {
  background-color: #f7f8fa;
  width: 100%;
  height: 100%;
}

.page-root {
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* 头部沉浸式适配 */
.header {
  background-color: #f7f8fa;
  width: 100%;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.back-btn { font-size: 44rpx; width: 60rpx; color: #333; }
.nav-title { font-size: 34rpx; font-weight: bold; }

/* 内容主体 */
.main-body {
  padding: 30rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 搜索框 */
.search-box {
  background: #fff;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  border: 1rpx solid #eee;
  margin-bottom: 40rpx;
}
.search-box input { margin-left: 15rpx; font-size: 28rpx; flex: 1; }

/* 学员卡片 */
.student-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background-color: #6b5af0; /* 紫色系列 */
  border-radius: 50%;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 24rpx;
}

.info-area { flex: 1; }
.name-row { display: flex; align-items: center; margin-bottom: 8rpx; }
.name { font-size: 32rpx; font-weight: bold; color: #333; margin-right: 15rpx; }

/* 状态标签 */
.tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.active-tag { background: #e8f5ed; color: #2d7d52; }
.end-tag { background: #f5f5f5; color: #999; }

.detail { font-size: 24rpx; color: #999; }
.arrow-icon { color: #ccc; font-size: 30rpx; }