<view class="page-container">
  <view class="nav-fixed" style="padding-top: {{navTop}}px;">
    <view class="nav-content" style="height: {{navHeight}}px;">
      <view class="back-btn" bindtap="goBack">〈</view>
      <text class="title">订单管理</text>
    </view>
    <view class="tab-box">
      <view wx:for="{{tabs}}" wx:key="index" 
            class="tab-item {{activeTab == index ? 'active' : ''}}"
            bindtap="switchTab" data-index="{{index}}">
        {{item}}
        <view class="line" wx:if="{{activeTab == index}}"></view>
      </view>
    </view>
  </view>

  <view class="order-body" style="margin-top: {{navTop + navHeight + 50}}px;">
    <view class="order-card" wx:for="{{orderList}}" wx:key="id">
      <view class="card-top">
        <text class="order-no">订单号：{{item.id}}</text>
        <text class="status-txt {{item.status == 1 ? 'red' : ''}}">{{item.statusText}}</text>
      </view>
      
      <view class="card-mid">
        <view class="course-info">
          <text class="c-name">{{item.courseName}}</text>
          <text class="u-name">学生：{{item.childName}}</text>
        </view>
        <text class="price">¥{{item.price}}</text>
      </view>
      
      <view class="card-bottom">
        <text class="date">{{item.date}}</text>
        <view class="btn-group">
          <view class="btn-secondary" wx:if="{{item.status == 2}}">查看合同</view>
          <view class="btn-primary" wx:if="{{item.status == 1}}">立即支付</view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{orderList.length == 0}}">
      <text>暂无相关订单记录</text>
    </view>
  </view>
</view>