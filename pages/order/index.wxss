page { background-color: #F8FAFC; }

/* 头部固定导航及Tab */
.nav-fixed {
  position: fixed; top: 0; left: 0; width: 100%;
  background: #F8FAFC; z-index: 100;
}
.nav-content {
  display: flex; align-items: center; padding: 0 32rpx;
}
.back-btn { font-size: 40rpx; color: #1E293B; font-weight: bold; width: 60rpx; }
.title { font-size: 34rpx; font-weight: 600; color: #0F172A; }

.tab-box {
  display: flex; height: 90rpx; background: #F8FAFC;
  padding: 0 40rpx; align-items: center; justify-content: space-between;
}
.tab-item {
  font-size: 28rpx; color: #64748B; position: relative;
  height: 100%; display: flex; align-items: center;
}
.tab-item.active { color: #3B82F6; font-weight: 600; }
.tab-item .line {
  position: absolute; bottom: 10rpx; left: 50%; transform: translateX(-50%);
  width: 32rpx; height: 6rpx; background: #3B82F6; border-radius: 4rpx;
}

/* 订单卡片列表 */
.order-body { padding: 20rpx 32rpx; }

.order-card {
  background: #FFFFFF; border-radius: 24rpx; padding: 32rpx;
  margin-bottom: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.card-top {
  display: flex; justify-content: space-between; border-bottom: 1rpx solid #F1F5F9;
  padding-bottom: 20rpx; margin-bottom: 24rpx;
}
.order-no { font-size: 24rpx; color: #94A3B8; }
.status-txt { font-size: 24rpx; color: #3B82F6; font-weight: 500; }
.status-txt.red { color: #EF4444; }

.card-mid { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30rpx; }
.c-name { font-size: 30rpx; font-weight: 600; color: #1E293B; display: block; margin-bottom: 8rpx; }
.u-name { font-size: 24rpx; color: #64748B; }
.price { font-size: 32rpx; font-weight: 700; color: #0F172A; }

.card-bottom {
  display: flex; justify-content: space-between; align-items: center;
}
.date { font-size: 22rpx; color: #94A3B8; }

.btn-group { display: flex; }
.btn-primary {
  background: #3B82F6; color: #fff; font-size: 24rpx;
  padding: 12rpx 30rpx; border-radius: 30rpx; margin-left: 16rpx;
}
.btn-secondary {
  border: 1.5rpx solid #E2E8F0; color: #64748B; font-size: 24rpx;
  padding: 12rpx 30rpx; border-radius: 30rpx;
}

.empty-state { text-align: center; padding-top: 200rpx; color: #94A3B8; font-size: 28rpx; }