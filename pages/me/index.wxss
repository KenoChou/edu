page { background-color: #f7f8fa; }
.li-icon{  margin-right: 24rpx;}
/* 主题渐变还原 */
.theme-parent .header-bg { background: linear-gradient(180deg, #f39c12 0%, #ffb347 100%); }
.theme-teacher .header-bg { background: linear-gradient(180deg, #3a86ff 0%, #52b1ff 100%); }

.header-bg { padding: 0 40rpx 100rpx; box-sizing: border-box; }

/* 导航切换 */
.nav-bar { display: flex; align-items: center; justify-content: space-between; margin-top: 10rpx; }
.role-selector { display: flex; background: rgba(255,255,255,0.2); border-radius: 40rpx; padding: 4rpx; }
.role-item { padding: 8rpx 30rpx; color: #fff; font-size: 24rpx; border-radius: 36rpx; }
.role-item.active { background: #fff; color: #3a86ff; font-weight: bold; }
.header-icons { display: flex; gap: 30rpx; color: #fff; font-size: 38rpx; margin-right: 200rpx; }

/* 用户信息布局 */
.user-section { display: flex; align-items: center; margin-top: 40rpx; }
.avatar-main { width: 110rpx; height: 110rpx; background: #eee; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; font-weight: bold; }
.avatar-group { position: relative; }
.avatar-badge { position: absolute; bottom: 0; right: 0; background: #fff; width: 34rpx; height: 34rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; }
.user-text { margin-left: 24rpx; color: #fff; flex: 1; }
.user-name { font-size: 42rpx; font-weight: bold; }
.status-tag { font-size: 20rpx; border: 1rpx solid #fff; padding: 2rpx 12rpx; border-radius: 20rpx; margin-left: 10rpx; vertical-align: middle; }
.user-id { font-size: 24rpx; opacity: 0.8; display: block; margin-top: 6rpx; }

/* 统计数据 */
.stats-bar { display: flex; justify-content: space-around; margin-top: 60rpx; color: #fff; text-align: center; }
.s-val { font-size: 44rpx; font-weight: bold; display: block; }
.s-lab { font-size: 24rpx; opacity: 0.8; margin-top: 4rpx; }

/* 内容容器偏移 */
.main-content { padding: 0 30rpx; margin-top: -60rpx; padding-bottom: 60rpx; }

/* 通用卡片样式 */
.card { background: #fff; border-radius: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); }

/* 家长版 3宫格还原 */
.grid-card.is-parent { display: flex; justify-content: space-around; padding: 40rpx 10rpx; }
/* 教师版 8宫格 */
.grid-card.is-teacher { display: grid; grid-template-columns: repeat(4, 1fr); row-gap: 40rpx; padding: 40rpx 0; }

.grid-item { display: flex; flex-direction: column; align-items: center; }
.icon-wrap { width: 100rpx; height: 100rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; margin-bottom: 12rpx; }
.item-name { font-size: 24rpx; color: #333; }

/* 横幅细节 */
.banner-card { padding: 30rpx; display: flex; justify-content: space-between; align-items: center; }
.b-left { display: flex; align-items: center; }
.b-icon { width: 80rpx; height: 80rpx; background: #eef2ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-right: 20rpx; }
.b-title { font-size: 30rpx; font-weight: bold; }
.b-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.b-btn { color: #fff; font-size: 24rpx; padding: 14rpx 32rpx; border-radius: 40rpx; }
.btn-primary { background: #3e52e8; }
.btn-blue { background: #4a80ff; }

/* 列表项 */
.list-card { padding: 0 30rpx; }
.list-item { display: flex; justify-content: space-between; align-items: center; padding: 36rpx 0; border-bottom: 1rpx solid #f8f8f8; font-size: 28rpx; }
.v-tag { color: #3a86ff; background: #eef6ff; font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; margin-right: 10rpx; }
.arrow { color: #ccc; }

/* 退出登录 */
.logout-btn { background: #fff; color: #999; font-size: 30rpx; margin-top: 20rpx; border-radius: 24rpx; }

/* 图标颜色库 */
.bg-orange { background: #fff7ed; }
.bg-blue { background: #eff6ff; }
.bg-green { background: #f0fdf4; }
.bg-indigo { background: #eef2ff; }
.bg-red { background: #fef2f2; }
.bg-cyan { background: #ecfeff; }
.bg-purple { background: #faf5ff; }
.bg-gray { background: #f9fafb; }