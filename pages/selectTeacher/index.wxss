page { background: #f8f9fb; }

/* 导航栏修复：显式绘制返回箭头 */
.nav-bar { background: #fff; position: fixed; top: 0; width: 100%; z-index: 1000; }
.nav-content { display: flex; align-items: center; justify-content: center; position: relative; }
.nav-title { font-size: 34rpx; font-weight: bold; color: #000; }
.back-action { position: absolute; left: 20rpx; width: 80rpx; height: 100%; display: flex; align-items: center; justify-content: center; z-index: 1001; }
.back-arrow-black { 
  width: 20rpx; height: 20rpx; 
  border-left: 4rpx solid #333; border-bottom: 4rpx solid #333; 
  transform: rotate(45deg); 
}

/* 卡片布局加固 */
.list-container { padding-top: 20rpx; }
.teacher-card {
  margin: 0 30rpx 24rpx; background: #fff; border-radius: 28rpx; padding: 32rpx;
  display: flex; align-items: center; 
  border: 4rpx solid transparent; box-sizing: border-box;
}
.teacher-card.active { border-color: #3a86ff; background: #f4f9ff; }

/* 重点：防止挤压的关键属性 */
.ai-box, .avatar-zh {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  flex-shrink: 0; /* 强制不缩放 */
  display: flex; align-items: center; justify-content: center;
}
.ai-box { background: #eef3ff; font-size: 50rpx; border-radius: 20rpx; }
.avatar-zh { background: #ffdada; color: #ff5e5e; font-weight: bold; }

.info-content { flex: 1; margin: 0 24rpx; min-width: 0; /* 允许内部文字省略而不撑开容器 */ }
.main-name { font-size: 32rpx; font-weight: bold; color: #333; }
.sub-text { font-size: 26rpx; color: #999; margin-top: 8rpx; }

/* 右侧操作区加固 */
.right-action-area {
  display: flex; flex-direction: column; align-items: flex-end;
  flex-shrink: 0; /* 强制不缩放，确保按钮可见 */
  min-width: 140rpx;
}
.cert-link-btn {
  font-size: 24rpx; color: #3a86ff; border: 1rpx solid #3a86ff;
  padding: 6rpx 20rpx; border-radius: 30rpx; margin-bottom: 20rpx;
  white-space: nowrap; /* 强制文字不换行 */
}

/* 选中状态图标 */
.check-circle { width: 40rpx; height: 40rpx; border: 2rpx solid #ddd; border-radius: 50%; box-sizing: border-box; }
.check-circle.active {
  background: #3a86ff; border: none; position: relative;
}
.check-circle.active::after {
  content: ''; position: absolute; width: 18rpx; height: 10rpx;
  border-left: 4rpx solid #fff; border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg); top: 12rpx; left: 11rpx;
}