<view class="page-container">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-content" style="height: {{navHeight}}px">
      <view class="back-action" bindtap="goBack">
        <view class="back-arrow-black"></view>
      </view>
      <text class="nav-title">选择授课老师</text>
    </view>
  </view>

  <scroll-view scroll-y class="list-container" style="margin-top: {{statusBarHeight + navHeight}}px">
    <view
      class="teacher-card {{selectedId === 'ai' ? 'active' : ''}}"
      bindtap="onSelect"
      data-id="ai"
    >
      <view class="ai-box">🤖</view>
      <view class="info-content">
        <view class="main-name">系统智能推荐</view>
        <view class="sub-text">快速匹配 · 优选师资</view>
      </view>
      <view class="check-circle {{selectedId === 'ai' ? 'active' : ''}}"></view>
    </view>

    <view
      class="teacher-card {{selectedId === 'teacher1' ? 'active' : ''}}"
      bindtap="onSelect"
      data-id="teacher1"
    >
      <view class="avatar-zh">ZH</view>
      <view class="info-content">
        <view class="name-row">
          <text class="main-name">张雅琴</text>
          <text class="star-label">★ 5</text>
        </view>
        <view class="tags">
          <text class="tag-item">中央音乐学院</text>
          <text class="tag-item">5年教龄</text>
        </view>
      </view>
      <view class="right-action-area">
        <view class="cert-link-btn" catchtap="viewCert">查看资质</view>
        <view class="check-circle {{selectedId === 'teacher1' ? 'active' : ''}}"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 资质详情弹窗 -->
  <view class="cert-modal" wx:if="{{showCertModal}}">
    <view class="cert-backdrop" bindtap="hideCertModal"></view>
    <view class="cert-panel" catchtap="noop">
      <view class="cert-header">
        <text class="cert-title">资质信息</text>
        <view class="cert-close" bindtap="hideCertModal">×</view>
      </view>
      <view class="cert-body">
        <image class="cert-img" src="{{modalCert.image}}" mode="aspectFit"></image>
        <view class="cert-info">
          <view class="cert-row"><text class="label">证书名：</text><text>{{modalCert.name}}</text></view>
          <view class="cert-row"><text class="label">颁发日期：</text><text>{{modalCert.date}}</text></view>
          <view class="cert-row"><text class="label">状态：</text><text>{{modalCert.status}}</text></view>
          <view class="cert-row"><text class="label">颁发机构：</text><text>{{modalCert.issuer || '——'}}</text></view>
        </view>
      </view>
      <view class="cert-footer">
        <view class="btn btn-close" bindtap="hideCertModal">关闭</view>
      </view>
    </view>
  </view>
</view>
