page {
  background-color: #F8FAFC;
  width: 100%;
}

.content-scroll {
  padding: 0 40rpx 40rpx;
}

.child-profile {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 50rpx;
}

.avatar-circle {
  width: 100rpx; height: 100rpx;
  background: linear-gradient(135deg, #3B82F6, #60A5FA);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #FFF; font-size: 40rpx; font-weight: bold; margin-right: 24rpx;
}

.child-info { flex: 1; }
.name-box { display: flex; align-items: center; margin-bottom: 8rpx; }
.u-name { font-size: 34rpx; font-weight: 700; color: #1E293B; }
.u-tag { font-size: 20rpx; color: #3B82F6; background: #EFF6FF; padding: 2rpx 12rpx; border-radius: 6rpx; margin-left: 12rpx; }
.u-sub { font-size: 24rpx; color: #94A3B8; }

.switch-btn {
  font-size: 24rpx; color: #3B82F6; padding: 10rpx 24rpx;
  border: 1.5rpx solid #DBEAFE; border-radius: 30rpx;
}

.course-item {
  background: #FFF; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.course-head { display: flex; justify-content: space-between; margin-bottom: 24rpx; }
.course-name { font-size: 28rpx; font-weight: 600; color: #1E293B; }
.teacher-name { font-size: 24rpx; color: #94A3B8; }

.progress-box { display: flex; align-items: center; margin-bottom: 12rpx; }
.bar-bg { flex: 1; height: 12rpx; background: #F1F5F9; border-radius: 6rpx; overflow: hidden; margin-right: 20rpx; }
.bar-fill { height: 100%; background: #3B82F6; border-radius: 6rpx; }
.percent-txt { font-size: 24rpx; font-weight: 600; color: #3B82F6; width: 60rpx; }

.course-foot { text-align: right; font-size: 22rpx; color: #94A3B8; }

.add-child-entry {
  margin-top: 40rpx;
  height: 110rpx;
  border: 2rpx dashed #CBD5E1;
  border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  color: #3B82F6; font-size: 28rpx; font-weight: 600;
}

.plus-icon {
  width: 40rpx; height: 40rpx; background: #3B82F6; color: #fff;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  margin-right: 16rpx; font-size: 32rpx;
}
