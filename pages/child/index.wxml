<view class="page-container">
  <ui-page-nav
    top="{{navTop}}"
    height="{{navHeight}}"
    title="我的孩子"
    background="#F8FAFC"
    backIcon="〈"
    fixed="{{true}}"
    bind:back="goBack"
  />

  <view class="content-scroll" style="margin-top: 10px;">
    <ui-child-profile child="{{childList[activeChildIndex]}}" bind:switch="switchChild" />

    <ui-section-title title="在读课程进度" />
    <view class="course-list">
      <ui-course-card wx:for="{{childList[activeChildIndex].courses}}" wx:key="id" course="{{item}}" />
    </view>

    <ui-dashed-action text="绑定/添加其他孩子" icon="+" bind:tap="addChild" />
  </view>
</view>
